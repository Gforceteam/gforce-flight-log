# Gforce API — copy to `.env` for local development (never commit `.env`)

# Required — issue a long random string for production (Fly: `fly secrets set JWT_SECRET=...`)
JWT_SECRET=change-me-to-a-long-random-string

# Required — office staff login password (Fly: `fly secrets set OFFICE_PASSWORD=...`)
OFFICE_PASSWORD=your-office-password

# Required — Turso LibSQL (dashboard: https://turso.tech — create a database and auth token)
TURSO_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Optional — fixed value for office session refresh (`POST /api/auth/refresh-office`)
# If unset, a derived fallback is used at login time; refresh may fail until this matches.
# OFFICE_REFRESH_SECRET=long-random-string

# Optional — Web Push (VAPID keys). Generate with `npx web-push generate-vapid-keys`
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=

# Optional — GitHub PAT for daily CSV backups to a private repo (see `GITHUB_BACKUP_REPO` in server.js)
# GITHUB_TOKEN=
# GITHUB_BACKUP_REPO=owner/private-repo-name

# Optional — comma-separated extra CORS origins (e.g. `http://192.168.1.10:8080`)
# ALLOWED_ORIGINS=

# Local server port (Fly sets PORT automatically)
PORT=3000
